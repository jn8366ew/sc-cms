# ─── 의존성 ───────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*

# Yarn Berry (zero-install 미사용 시)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js 빌드 산출물 ──────────────────────────────────
/.next/
/out/
/build

# ─── 환경 변수 ────────────────────────────────────────────
# .env.example 은 커밋 대상 — 나머지는 제외
.env
.env.*
!.env.example

# ─── 테스트 ───────────────────────────────────────────────
/coverage
/test-results/
/playwright-report/
/playwright/.cache/

# ─── 로그 ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── TypeScript ────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── 배포 ─────────────────────────────────────────────────
.vercel

# ─── OS ───────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── IDE ──────────────────────────────────────────────────
.vscode/
.cursor/
*.code-workspace
.history/
.idea/
*.iml
*.iws
*.ipr

# ─── 프로젝트 로컬 파일 ────────────────────────────────────
docs/prd copy.md
